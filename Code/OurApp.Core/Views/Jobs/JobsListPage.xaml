<Page
    x:Class="iss_project.UI.Views.Jobs.JobsListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Jobs"
                   FontSize="24"
                   Margin="0,0,0,10"/>

        <!-- Scrollable list -->
        <ListView Grid.Row="1"
                  ItemsSource="{Binding Jobs}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Spacing="5" Margin="5">
                        <TextBlock Text="{Binding JobTitle}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding IndustryField}" />
                        <TextBlock Text="{Binding JobLocation}" />
                        <TextBlock Text="{Binding AvailablePositions}" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Bottom button -->
        <Button Grid.Row="2"
                Content="Back to Create Job"
                Click="GoToCreate"
                HorizontalAlignment="Stretch"
                Margin="0,10,0,0"/>
    </Grid>
</Page>