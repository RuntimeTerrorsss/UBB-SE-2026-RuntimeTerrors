<Page
    x:Class="iss_project.UI.Views.Jobs.JobsListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Jobs"
                   FontSize="24"
                   Margin="0,0,0,10"/>

        <!-- Scrollable list -->
        <ListView Grid.Row="1"
          ItemsSource="{Binding Jobs}">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="5"
            Padding="12"
            CornerRadius="8"
            BorderBrush="Gray"
            BorderThickness="1">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Job Info -->
                            <StackPanel Spacing="6">

                                <TextBlock Text="{Binding JobTitleDisplay}"
           FontSize="16"
           FontWeight="Bold"/>

                                <TextBlock Text="{Binding IndustryFieldDisplay}" />
                                <TextBlock Text="{Binding JobTypeDisplay}" />
                                <TextBlock Text="{Binding ExperienceLevelDisplay}" />
                                <TextBlock Text="{Binding JobLocationDisplay}" />

                                <TextBlock Text="{Binding PositionsDisplay}"/>

                                <TextBlock Text="{Binding StartDateDisplay}"
           Visibility="{Binding StartDateVisibility}"/>

                                <TextBlock Text="{Binding EndDateDisplay}"
           Visibility="{Binding EndDateVisibility}"/>

                                <TextBlock Text="{Binding DeadlineDisplay}"
           Visibility="{Binding DeadlineVisibility}"/>

                                <TextBlock Text="{Binding SalaryDisplay}"
           Visibility="{Binding SalaryVisibility}"/>

                                <TextBlock Text="{Binding AmountPayedDisplay}"
           Visibility="{Binding AmountPayedVisibility}"/>

                                <TextBlock Text="{Binding PostedAtDisplay}"
           Visibility="{Binding PostedAtVisibility}"/>

                                <TextBlock Text="{Binding DescriptionDisplay}"
           TextWrapping="Wrap"
           MaxLines="3"/>

                            </StackPanel>

                            <!-- 3-dot menu -->
                            <Button Grid.Column="1"
                    Content="⋯"
                    FontSize="18"
                    Padding="10"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top">

                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Edit"
                                        Click="EditJob_Click"
                                        Tag="{Binding}" />

                                        <MenuFlyoutItem Text="Delete"
                                        Click="DeleteJob_Click"
                                        Tag="{Binding}" />
                                    </MenuFlyout>
                                </Button.Flyout>

                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10">
            <Button Content="Back"
            Click="GoBack"
            HorizontalAlignment="Stretch"
            Width="150"/>

            <Button Content="Create Post"
            Click="GoToAddJob"
            Width="150"/>
        </StackPanel>
    </Grid>
</Page>