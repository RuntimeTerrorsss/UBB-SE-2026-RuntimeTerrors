<Page
    x:Class="iss_project.UI.Views.Jobs.EditJobPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid Padding="20">
            <StackPanel Spacing="10">

                <!-- Title -->
                <TextBox Header="Title"
                         Text="{Binding Job.JobTitle, Mode=TwoWay}" />

                <!-- Industry -->
                <TextBox Header="Industry Field"
                         Text="{Binding Job.IndustryField, Mode=TwoWay}" />

                <ComboBox Header="Job Type"
          ItemsSource="{Binding JobTypes}"
          SelectedValue="{Binding Job.JobType, Mode=TwoWay}" />

                <ComboBox Header="Experience Level"
          ItemsSource="{Binding ExperienceLevels}"
          SelectedValue="{Binding Job.ExperienceLevel, Mode=TwoWay}" />

                <!-- Description -->
                <TextBox Header="Description"
                         Text="{Binding Job.JobDescription, Mode=TwoWay}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="100"/>

                <!-- Location -->
                <TextBox Header="Location"
                         Text="{Binding Job.JobLocation, Mode=TwoWay}" />

                <!-- Positions -->
                <TextBox Header="Available Positions"
                         Text="{Binding Job.AvailablePositions, Mode=TwoWay}" />

                <!-- Dates -->
                <DatePicker Date="{Binding StartDate, Mode=TwoWay}" />
                <DatePicker Date="{Binding EndDate, Mode=TwoWay}" />
                <DatePicker Date="{Binding Deadline, Mode=TwoWay}" />

                <!-- Financials -->
                <TextBox Header="Salary"
                         Text="{Binding Job.Salary, Mode=TwoWay}" />

                <TextBox Header="Amount Paid"
                         Text="{Binding Job.AmountPayed, Mode=TwoWay}" />

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Save" Click="Save_Click"/>
                    <Button Content="Cancel" Click="Cancel_Click"/>
                </StackPanel>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>