<Page
    x:Class="iss_project.UI.Views.Jobs.CreateJobPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:iss_project.UI.Converters">

    <Page.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    </Page.Resources>

    <ScrollViewer>
        <Grid Padding="20">

            <StackPanel Spacing="10">

                <TextBox Header="Title" Text="{Binding JobTitle, Mode=TwoWay}" />

                <TextBox Header="Industry Field" Text="{Binding IndustryField, Mode=TwoWay}" />

                <ComboBox Header="Job Type"
                          ItemsSource="{Binding JobTypes}"
                          SelectedItem="{Binding JobType, Mode=TwoWay}" />

                <ComboBox Header="Experience Level"
                          ItemsSource="{Binding ExperienceLevels}"
                          SelectedItem="{Binding ExperienceLevel, Mode=TwoWay}" />

                <TextBox Header="Description"
                         Text="{Binding JobDescription, Mode=TwoWay}"
                         AcceptsReturn="True"
                         Height="80"/>

                <TextBox Header="Location" Text="{Binding JobLocation, Mode=TwoWay}" />

                <TextBox Header="Available Positions"
                         Text="{Binding AvailablePositions, Mode=TwoWay}" />

                <TextBlock Text="Required Skills" FontSize="18" Margin="0,10,0,5"/>

                <ItemsControl ItemsSource="{Binding Skills}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="10">

                                <!-- Select skill -->
                                <CheckBox Content="{Binding SkillName}"
                          IsChecked="{Binding IsSelected, Mode=TwoWay}"/>

                                <!-- Percentage -->
                                <TextBox Width="60"
                         PlaceholderText="%"
                         Text="{Binding Percentage, Mode=TwoWay}"/>

                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Dates -->
                <DatePicker Header="Start Date"
                            Date="{Binding StartDate, Mode=TwoWay}" />

                <DatePicker Header="End Date"
                            Date="{Binding EndDate, Mode=TwoWay}" />

                <DatePicker Header="Deadline"
            Date="{Binding Deadline, Mode=TwoWay}"
            IsEnabled="{Binding UseAutomaticExpiration, Converter={StaticResource InverseBooleanConverter}}" />
                    
                <!-- Financial -->
                <TextBox Header="Salary"
                         Text="{Binding Salary, Mode=TwoWay}" />

                <TextBox Header="Amount Payed"
                         Text="{Binding AmountPayed, Mode=TwoWay}" />

                <CheckBox Content="Select automatic expiration date"
          IsChecked="{Binding UseAutomaticExpiration, Mode=TwoWay}" />

                <TextBox Header="Expiration Days"
         Text="{Binding ExpirationDays, Mode=TwoWay}"
         IsEnabled="{Binding UseAutomaticExpiration}" />

                <CheckBox Content="Schedule posting"
          IsChecked="{Binding UseScheduledPosting, Mode=TwoWay}" />

                <DatePicker Date="{Binding ScheduledAt, Mode=TwoWay}"
            IsEnabled="{Binding UseScheduledPosting}" />

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="POST" Click="CreateJob_Click"/>
                    <Button Content="Cancel" Click="GoBack"/>
                    <Button Content="Pay to Promote" Click="PayToPromote_Click"/>
                </StackPanel>

            </StackPanel>

        </Grid>
    </ScrollViewer>
</Page>