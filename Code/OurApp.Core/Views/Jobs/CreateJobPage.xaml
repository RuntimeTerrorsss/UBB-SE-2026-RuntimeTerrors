<Page
    x:Class="iss_project.UI.Views.Jobs.CreateJobPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Grid Padding="20">

		<StackPanel Spacing="10">

			

			<TextBox Header="Title" Text="{Binding JobTitle, Mode=TwoWay}" />
			<TextBox Header="Field" Text="{Binding IndustryField, Mode=TwoWay}" />
			<TextBox Header="Type" Text="{Binding JobType, Mode=TwoWay}" />
			<TextBox Header="Experience Level" Text="{Binding ExperienceLevel, Mode=TwoWay}" />

			<TextBox Header="Description" Text="{Binding JobDescription, Mode=TwoWay}" />
			<TextBox Header="Location" Text="{Binding JobLocation, Mode=TwoWay}" />

			<TextBox Header="Available Positions"
                     Text="{Binding AvailablePositions, Mode=TwoWay}" />

            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="Create Job" Click="CreateJob_Click"/>
                <Button Content="Cancel" Click="GoBack"/>
            </StackPanel>

        </StackPanel>

	</Grid>
</Page>