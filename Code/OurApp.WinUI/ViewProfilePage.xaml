<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OurApp.WinUI.ViewProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:OurApp.Core.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="32" Spacing="24" MaxWidth="1400" HorizontalAlignment="Stretch">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="4">
                    <Ellipse Width="80" Height="80" StrokeThickness="1" Stroke="{ThemeResource CardStrokeColorDefaultBrush}">
                        <Ellipse.Fill>
                            <ImageBrush x:Name="CompanyLogoBrush" Stretch="UniformToFill" />
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock x:Name="CompanyLogoHintText"
                               Text="(logo)"
                               TextWrapping="Wrap"
                               MaxWidth="120"
                               FontSize="10"
                               Opacity="0.7" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Company.Name}" FontSize="32" FontWeight="Bold" />
                    <TextBlock Text="{Binding LoadMessage}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" FontSize="14" TextWrapping="Wrap" />
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Edit profile"
                        VerticalAlignment="Center"
                        Command="{Binding EditProfileCommand}" />
            </Grid>

            <Border Padding="16" CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <TextBlock Text="{Binding ApplicantSummary}" FontWeight="SemiBold" TextWrapping="Wrap" />
            </Border>

            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock FontWeight="Bold" FontSize="18">
                            <Run Text="{Binding CompletedTasksCount}" />
                            <Run Text="/5 completed" />
                        </TextBlock>
                        <ProgressBar Value="{Binding CompletionPercentage}" Maximum="100" Height="8" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="32,0,0,0">
                        <TextBlock Text="Remaining tasks:" FontWeight="SemiBold" />
                        <ItemsControl ItemsSource="{Binding RemainingTasks}" Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Margin="0,2,0,0" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0" Spacing="24">

                    <StackPanel Spacing="12">
                        <TextBlock Text="About us" FontSize="20" FontWeight="Bold" />
                        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" MinHeight="120" Padding="16">
                            <TextBlock Text="{Binding Company.AboutUs}" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>

                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="24">
                        <StackPanel Spacing="12">
                            <Grid>
                                <TextBlock Text="Posted jobs (preview)" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding JobPreview}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CompanyProfileListRow">
                                        <StackPanel Margin="0,0,0,12" Spacing="4">
                                            <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind Subtitle}" TextWrapping="Wrap" Opacity="0.85" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="24">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Events (preview)" FontSize="20" FontWeight="Bold" />
                            <ItemsControl ItemsSource="{Binding EventPreview}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CompanyProfileListRow">
                                        <StackPanel Margin="0,0,0,12" Spacing="4">
                                            <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind Subtitle}" TextWrapping="Wrap" Opacity="0.85" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="24">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Office well-being mini-game (what candidates see)" FontSize="20" FontWeight="Bold" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Buddy:" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Company.BuddyName}" TextWrapping="Wrap" />
                            </StackPanel>
                            <TextBlock Text="Scenario 1" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Company.Scenario1Text}" TextWrapping="Wrap" />
                            <TextBlock Text="Scenario 2" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Company.Scenario2Text}" TextWrapping="Wrap" />
                            <TextBlock Text="Closing quote" FontWeight="SemiBold" Opacity="0.9" />
                            <TextBlock Text="{Binding Company.FinalQuote}" TextWrapping="Wrap" Opacity="0.8" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="24">

                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="24">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Contact" FontSize="20" FontWeight="Bold" />
                            <StackPanel Spacing="4">
                                <TextBlock Text="Location" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Company.Location}" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Email" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Company.Email}" TextWrapping="Wrap" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding CollaboratorLines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,8,0,0" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="24">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Trending skills" FontSize="20" FontWeight="Bold" />
                            <ItemsControl ItemsSource="{Binding TrendingSkills}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CompanyTrendingSkillRow">
                                        <StackPanel Margin="0,0,0,16" Spacing="4">
                                            <TextBlock FontWeight="SemiBold">
                                                <Run Text="{x:Bind Rank}" /><Run Text=". " /><Run Text="{x:Bind SkillName}" />
                                            </TextBlock>
                                            <TextBlock Text="{x:Bind Detail}" FontSize="12" Opacity="0.8" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
