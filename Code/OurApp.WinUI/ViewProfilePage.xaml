<Window 
    x:Class="App1.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="24" MaxWidth="1400" HorizontalAlignment="Stretch">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Ellipse Grid.Column="0" Width="80" Height="80" StrokeThickness="1" Stroke="Gray" />
                <TextBlock Grid.Column="0" Text="Logo" HorizontalAlignment="Center" VerticalAlignment="Center" />

                <TextBlock Grid.Column="1" Text="Company Name" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" Margin="24,0,0,0" />
            </Grid>

            <Border Padding="16" CornerRadius="8" BorderThickness="1" BorderBrush="Gray">
                <TextBlock Text="Congrats!! You have 9% more applicants than last month!" FontWeight="SemiBold" />
            </Border>

            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="12" Padding="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock Text="2/5 completed" FontWeight="Bold" FontSize="18"/>
                        <ProgressBar Value="40" Maximum="100" Height="8" CornerRadius="4"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="32,0,0,0">
                        <TextBlock Text="Next things to do:" FontWeight="SemiBold" />
                        <TextBlock Text="- collab with 2 companies (1/2 done)" Margin="0,4,0,0" />
                        <TextBlock Text="- post 5 jobs (2/5 done)" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">

                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="About us" FontSize="20" FontWeight="Bold" Margin="0,0,0,12" />
                        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="12" MinHeight="150" Padding="16">
                            <TextBlock Text="Company details and description go here..." TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>

                    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="12" Padding="24" Margin="0,0,0,24">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <TextBlock Text="Posted Jobs" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                                <Button Content="See all" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="3*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Job title" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="Job description snippet..." />
                                </Grid>
                                <Border Height="1" Background="LightGray" Margin="0,8" HorizontalAlignment="Stretch" />
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="3*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Job title" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="Job description snippet..." />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="12" Padding="24">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <TextBlock Text="Events" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                                <Button Content="See all" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Event descriptions here..." />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="12,0,0,0">

                    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="12" Padding="24" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="Contact us!" FontSize="20" FontWeight="Bold" Margin="0,0,0,16" />
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="Location:" FontWeight="SemiBold" />
                                <TextBlock Text="123 Business Rd, Tech City" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Email:" FontWeight="SemiBold" />
                                <TextBlock Text="contact@company.com" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="12" Padding="24">
                        <StackPanel>
                            <TextBlock Text="Trending now!!!" FontSize="20" FontWeight="Bold" Margin="0,0,0,16" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="1. Python" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="65%" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="2. CSS" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="36%" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="3. C#" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="20%" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Window>