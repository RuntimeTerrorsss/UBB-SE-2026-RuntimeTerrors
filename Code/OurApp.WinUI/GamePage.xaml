<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OurApp.WinUI.GamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OurApp.WinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <StackPanel Padding="40" Spacing="25" HorizontalAlignment="Center" VerticalAlignment="Center">

            <StackPanel Visibility="{x:Bind ViewModel.IsStartVisible, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <Button Content="Edit Game"
                    Click="NavigateToEditGame_Click"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind ViewModel.WelcomeMessage, Mode=OneWay}" 
                FontSize="28" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" 
                TextAlignment="Center" Margin="0,0,0,20"/>
                <Button Content="Să începem!" Click="OnStartGameClick" HorizontalAlignment="Center" Padding="20,10"/>
            </StackPanel>

            <StackPanel Visibility="{x:Bind ViewModel.IsChoiceActive, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{x:Bind ViewModel.CurrentQuestion, Mode=OneWay}" 
                FontSize="18" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="500" Margin="0,0,0,20"/>

                <ItemsControl ItemsSource="{x:Bind ViewModel.CurrentChoices, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Button Content="{Binding}" Margin="0,5,0,5" HorizontalAlignment="Stretch"
                         Click="OnChoiceButtonClick"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <StackPanel Visibility="{x:Bind ViewModel.IsReactionActive, Mode=OneWay, Converter={StaticResource BoolToVis}}" Spacing="20">
                <TextBlock Text="Reacția colegului:" FontSize="14" Foreground="Gray" TextAlignment="Center"/>
                <TextBlock Text="{x:Bind ViewModel.Feedback, Mode=OneWay}" 
                FontSize="20" FontStyle="Italic" Foreground="LightGreen" 
                TextAlignment="Center" TextWrapping="Wrap" MaxWidth="450"/>
                <Button Content="Continuă" Click="OnNextStepClick" HorizontalAlignment="Center" Style="{StaticResource AccentButtonStyle}"/>
            </StackPanel>

            <StackPanel Visibility="{x:Bind ViewModel.IsConclusionVisible, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Concluzie" FontSize="28" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="{x:Bind ViewModel.Feedback, Mode=OneWay}" FontSize="18" TextAlignment="Center" MaxWidth="500"/>
                <Button Content="Ieșire" Click="OnExitClick" HorizontalAlignment="Center" Margin="0,30,0,0"/>
            </StackPanel>

        </StackPanel>
        <Frame x:Name="gameFrame" Margin="0,30,0,0"/>
    </Grid>
</Page>
