<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OurApp.WinUI.EditProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="32" Spacing="20" MaxWidth="900" HorizontalAlignment="Stretch">

                <Button Content="Back" HorizontalAlignment="Left" Click="NavigateBack_Click" />

                <TextBlock Text="Edit company profile" FontSize="28" FontWeight="Bold" />

                <TextBlock Text="{Binding StatusMessage}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" TextWrapping="Wrap"
                           IsTextSelectionEnabled="True" />

                <TextBlock Text="Required fields depend on your validators (name and logo are required)." Opacity="0.7" TextWrapping="Wrap" />

                <TextBlock Text="Basic details" FontSize="20" FontWeight="SemiBold" />
                <TextBox Header="Company name" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Header="About us" Text="{Binding AboutUs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True"
                         TextWrapping="Wrap" MinHeight="120" />
                <StackPanel>
                    <TextBlock Text="Profile picture (.jpg / .jpeg / .png path or URL)"/>
                    <Button Content="Attach image" Click="AttachProfileImage_Click" />
                    <Image
                        x:Name="PhotoPreviewImage"
                        Width="200"
                        Height="200"
                        Stretch="UniformToFill"
                        Margin="0,10,0,5" />
                    <TextBlock
                        x:Name="PhotoFileNameTextBlock"
                        FontSize="12"
                        Foreground="Gray"
                        Text="No image selected" />
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Logo (.jpg / .jpeg / .png path or URL, required)"/>
                    <Button Content="Attach image" Click="AttachLogoImage_Click" />
                    <Image
                        x:Name="LogoPreviewImage"
                        Width="200"
                        Height="200"
                        Stretch="UniformToFill"
                        Margin="0,10,0,5" />
                    <TextBlock
                        x:Name="LogoFileNameTextBlock"
                        FontSize="12"
                        Foreground="Gray"
                        Text="No image selected" />
                </StackPanel>

                <TextBox Header="Location" Text="{Binding Location, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Header="Contact email" Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Mini-game (buddy &amp; scenarios)" FontSize="20" FontWeight="SemiBold" Margin="0,16,0,0" />
                <TextBox Header="Buddy display name" Text="{Binding BuddyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Header="Closing / motivational quote" Text="{Binding FinalQuote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" />

                <TextBlock Text="Scenario 1" FontWeight="SemiBold" />
                <TextBox Header="Buddy struggle" Text="{Binding Scenario1Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80" />
                <TextBox Header="Response 1" Text="{Binding Scenario1Answer1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Header="Response 2" Text="{Binding Scenario1Answer2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Header="Response 3" Text="{Binding Scenario1Answer3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Header="Feedback if response 1 chosen" Text="{Binding Scenario1Reaction1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" />
                <TextBox Header="Feedback if response 2 chosen" Text="{Binding Scenario1Reaction2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" />
                <TextBox Header="Feedback if response 3 chosen" Text="{Binding Scenario1Reaction3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" />

                <TextBlock Text="Scenario 2" FontWeight="SemiBold" Margin="0,8,0,0" />
                <TextBox Header="Buddy struggle" Text="{Binding Scenario2Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80" />
                <TextBox Header="Response 1" Text="{Binding Scenario2Answer1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Header="Response 2" Text="{Binding Scenario2Answer2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Header="Response 3" Text="{Binding Scenario2Answer3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Header="Feedback if response 1 chosen" Text="{Binding Scenario2Reaction1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" />
                <TextBox Header="Feedback if response 2 chosen" Text="{Binding Scenario2Reaction2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" />
                <TextBox Header="Feedback if response 3 chosen" Text="{Binding Scenario2Reaction3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" />

                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,24,0,48">
                    <Button Content="Save" Style="{ThemeResource AccentButtonStyle}" Click="Save_Click" />
                    <Button Content="Cancel" Click="Cancel_Click" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
