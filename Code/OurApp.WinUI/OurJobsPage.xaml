<Page
    x:Class="OurApp.WinUI.OurJobsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OurApp.WinUI"
    xmlns:models="using:OurApp.Core.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header: always-visible back + title -->
        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,20">
            <Button Content="&#xE72B;"
                    FontFamily="Segoe Fluent Icons"
                    Click="BackButton_Click"/>
            <TextBlock Text="Our Jobs" VerticalAlignment="Center" FontSize="18"/>
        </StackPanel>

        <!-- Jobs List -->
        <ListView Grid.Row="1" 
                  ItemsSource="{x:Bind ViewModel.Jobs}" 
                  Visibility="{x:Bind ViewModel.JobsVisibility, Mode=OneWay}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:JobPosting">
                    <Grid Padding="10" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="{x:Bind JobTitle}"/>
                            <TextBlock Text="{x:Bind JobType}"/>
                        </StackPanel>
                        <!-- Applicants Button -->
                        <Button Grid.Column="1" 
                                Content="View Applicants" 
                                Click="ViewApplicantsButton_Click" 
                                Tag="{x:Bind}" 
                                VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>


    </Grid>
</Page>
