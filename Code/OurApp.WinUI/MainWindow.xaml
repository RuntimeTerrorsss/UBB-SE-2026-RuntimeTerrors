<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OurApp.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OurApp.WinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="OurApp.WinUI">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <CommandBar Background="Transparent" IsOpen="False" DefaultLabelPosition="Right">
            <AppBarButton Label="Profile">
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="View Profile" Click="NavigateToViewProfile_Click"/>
                        <MenuFlyoutItem Text="Edit Profile"/>
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>
            <AppBarButton Label="Our jobs"/>
            <AppBarButton Label="Past jobs"/>
            <AppBarButton Label="Our events"/>
            <AppBarButton Label="Past events"/>
        </CommandBar>

        <Frame x:Name="rootFrame"/>
    </Grid>
</Window>
