<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OurApp.WinUI.OurEventsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OurApp.WinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:OurApp.Core.Models"
    xmlns:converters="using:OurApp.WinUI.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:Base64ToImageSourceConverter x:Key="Base64ToImageSourceConverter" />
    </Page.Resources>
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="40">
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                    <Button Content="Back" HorizontalAlignment="Left" Click="NavigateBack_Click" />
                    <Button Content="Create Event" Click="CreateEventButton_Click"></Button>
                    <Button Content="Past events" Click="PastEventsButton_Click"></Button>
                    <Button Content="See Collaborators" Click="SeeCollaboratorsButton_Click"></Button>
                </StackPanel>

                <ListView ItemsSource="{Binding currentEventsCollection}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Event">
                            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Margin="0,0,0,10" Padding="10">
                                <Grid ColumnDefinitions="80,*, Auto">
                                    <Border Width="60" Height="60" CornerRadius="5">
                                        <Image
                                        Source="{Binding Photo, Converter={StaticResource Base64ToImageSourceConverter}}"
                                        Width="60"
                                        Height="60"
                                        Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16"/>
                                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Location}" FontStyle="Italic"/>
                                        <TextBlock Text="{Binding StartDate}" />
                                        <TextBlock Text="{Binding EndDate}" />
                                    </StackPanel>

                                    <Button 
                                    Content="..." 
                                    Grid.Column="2" 
                                    VerticalAlignment="Top" 
                                    Click="EditEvent_Click"
                                    Tag="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
