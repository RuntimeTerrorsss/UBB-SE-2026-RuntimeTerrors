<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OurApp.WinUI.EditGame"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12" Padding="20">
                <TextBlock Text="Create / Edit Game" FontSize="20" FontWeight="SemiBold" />

                <ComboBox
                    Header="Buddy id"
                    ItemsSource="{Binding AvailableBuddyIds}"
                    SelectedItem="{Binding SelectedBuddyId, Mode=TwoWay}" />

                <Image
                    Source="{Binding BuddyImagePath}"
                    Width="160"
                    Height="100"
                    Stretch="UniformToFill"
                    HorizontalAlignment="Left"
                    Margin="0,4,0,0" />

                <TextBox
                    Header="Coworker name"
                    Text="{Binding BuddyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="Name" />

                <TextBox
                    Header="Buddy introduction"
                    Text="{Binding BuddyIntroduction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="Introduction" />

                <TextBlock Text="Scenarios" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,0" />

                <ListView ItemsSource="{Binding Scenarios}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="10" Padding="10">
                                <TextBox
                                    Header="Scenario text"
                                    Text="{Binding ScenarioText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Scenario description" />

                                <ListView ItemsSource="{Binding Choices}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Spacing="8" Margin="0,0,0,10">
                                                <TextBox
                                                    Header="Advice"
                                                    Text="{Binding Advice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    PlaceholderText="Advice text" />
                                                <TextBox
                                                    Header="Feedback"
                                                    Text="{Binding Feedback, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    PlaceholderText="Feedback text"
                                                    AcceptsReturn="True"
                                                    MinHeight="60" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBox
                    Header="Conclusion"
                    Text="{Binding Conclusion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="Conclusion text"
                    AcceptsReturn="True"
                    MinHeight="80" />

                <Button
                    Content="Create / Save Game"
                    Command="{Binding CreateGameCommand}"
                    HorizontalAlignment="Left" />

                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
