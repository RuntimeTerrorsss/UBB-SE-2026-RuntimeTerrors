<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OurApp.WinUI.CreateEventPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OurApp.WinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <StackPanel>
            <TextBox 
                Header="Enter photo url:" 
                PlaceholderText="Photo"
                Text="{Binding Photo, Mode=TwoWay}"
            />

            <TextBox 
                x:Name="TitleBox"
                Header="* Enter event title:" 
                PlaceholderText="Title"
                Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                LostFocus="Title_LostFocus"
            />
            <TextBlock 
                x:Name="TitleError"
                Foreground="Red"
                FontSize="12"
            />

            <TextBox 
                x:Name="DescriptionBox"
                Header="Enter event description:" 
                PlaceholderText="Description"
                Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                LostFocus="Description_LostFocus"
            />
            <TextBlock 
                x:Name="DescriptionError"
                Foreground="Red"
                FontSize="12"
            />

            <CalendarDatePicker 
                x:Name="StartDatePicker"
                PlaceholderText="Pick a start date" 
                Header="Start date" 
                Date="{Binding StartDate, Mode=TwoWay}"
                DateChanged="StartDatePicker_DateChanged"
            />
            <TextBlock 
                x:Name="StartDateError"
                Foreground="Red"
                FontSize="12"
            />

            <CalendarDatePicker 
                x:Name="EndDatePicker"
                PlaceholderText="Pick a end date" 
                Header="End date" 
                Date="{Binding EndDate, Mode=TwoWay}"
                DateChanged="EndDatePicker_DateChanged"
            />
            <TextBlock 
                x:Name="EndDateError"
                Foreground="Red"
                FontSize="12"
            />

            <TextBox 
                x:Name="LocationBox"
                Header="Enter your location:" 
                PlaceholderText="Location"
                Text="{Binding Location, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                LostFocus="Location_LostFocus"
            />
            <TextBlock 
                x:Name="LocationError"
                Foreground="Red"
                FontSize="12"
            />

            <Button Content="Create Event" Command="{Binding TapCommand}"></Button>
        </StackPanel>
    </Grid>
</Page>
