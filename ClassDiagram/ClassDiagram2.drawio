        <UserObject label="&lt;pre&gt;                                                              ┌─────────────────────────────────────────────┐   &#xa;                                                              │PaymentWindow                                │   &#xa;                                                              ├─────────────────────────────────────────────┤   &#xa;                                                              │+ ViewModel : PaymentViewModel               │   &#xa;                                                              │+ PaymentWindow(int jobId)                   │   &#xa;                                                              │- ShowMessage(title: string, content: string)│   &#xa;                                                              └─────────────────────────────────────────────┘   &#xa;                                                                                     |                          &#xa;                                                                                     |                          &#xa;                                                          ┌────────────────────────────────────────────────────┐&#xa;                                                          │PaymentViewModel                                    │&#xa;                                                          ├────────────────────────────────────────────────────┤&#xa;                                                          │+ CurrentJobId : int                                │&#xa;                                                          │+ CardHolderName : string                           │&#xa;                                                          │+ CardNumber : string                               │&#xa;                                                          │+ ExpDate : string                                  │&#xa;                                                          │+ Cvv : string                                      │&#xa;                                                          │+ AmountToPayText : string                          │&#xa;                                                          │+ SelectedJobType : string                          │&#xa;                                                          │+ SelectedExperienceLevel : string                  │&#xa;                                                          │+ PaymentData : ObservableCollection&lt;JobPaymentInfo&gt;│&#xa;                                                          │+ ShowMessageAction : Action                        │&#xa;                                                          │+ CloseWindowAction : Action                        │&#xa;                                                          │+ Pay()                                             │&#xa;                                                          │+ Cancel()                                          │&#xa;                                                          │- LoadData()                                        │&#xa;                                                          └────────────────────────────────────────────────────┘&#xa;                                                                                                                &#xa;                                         ┌─────────────────────────────────────────────┐                        &#xa;                                         │PaymentService                               │                        &#xa;                                         ├─────────────────────────────────────────────┤                        &#xa;                                         │- _validator : PaymentValidator              │                        &#xa;                                         │- _repository : PaymentRepository            │                        &#xa;                                         │+ ProcessPayment(...) : string               │                        &#xa;                                         │+ GetPaidJobsInfo(...) : List&lt;JobPaymentInfo&gt;│                        &#xa;                                         │- SendNotificationEmails(...)                │                        &#xa;                                         └─────────────────────────────────────────────┘                        &#xa;                                                                 |                                              &#xa;                                                                                                                &#xa;                            ┌───────────────────────────────────────────────────────────────────────┐  |        &#xa;┌────────────────────────┐  │PaymentRepository                                                      │  |        &#xa;│PaymentValidator        │  ├───────────────────────────────────────────────────────────────────────┤  |        &#xa;├────────────────────────┤  │- _connectionString : string                                           │  |        &#xa;│+ Validate(...) : string│  │+ UpdateJobPayment(jobId: int, paymentAmount: int)                     │  |        &#xa;└────────────────────────┘  │+ GetPaidJobs(jobType: string, expLevel: string) : List&lt;JobPaymentInfo&gt;│  |        &#xa;                            │+ GetCompaniesToNotify(jobId: int, amount: int) : List&lt;string&gt;         │  |        &#xa;                            └───────────────────────────────────────────────────────────────────────┘  |        &#xa;                                                                                                                &#xa;                                                                         ┌──────────────────────┐               &#xa;                                                                         │JobPaymentInfo        │               &#xa;                                                                         ├──────────────────────┤               &#xa;                                                                         │+ CompanyName : string│               &#xa;                                                                         │+ JobTitle : string   │               &#xa;                                                                         │+ AmountPayed : int   │               &#xa;                                                                         └──────────────────────┘               &#xa;&lt;/pre&gt;" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam monochrome true\n\nclass PaymentWindow {\n  + ViewModel : PaymentViewModel\n  + PaymentWindow(int jobId)\n  - ShowMessage(title: string, content: string)\n}\n\nclass PaymentViewModel {\n  + CurrentJobId : int\n  + CardHolderName : string\n  + CardNumber : string\n  + ExpDate : string\n  + Cvv : string\n  + AmountToPayText : string\n  + SelectedJobType : string\n  + SelectedExperienceLevel : string\n  + PaymentData : ObservableCollection&lt;JobPaymentInfo&gt;\n  + ShowMessageAction : Action\n  + CloseWindowAction : Action\n  + Pay()\n  + Cancel()\n  - LoadData()\n}\n\nclass PaymentService {\n  - _validator : PaymentValidator\n  - _repository : PaymentRepository\n  + ProcessPayment(...) : string\n  + GetPaidJobsInfo(...) : List&lt;JobPaymentInfo&gt;\n  - SendNotificationEmails(...)\n}\n\nclass PaymentValidator {\n  + Validate(...) : string\n}\n\nclass PaymentRepository {\n  - _connectionString : string\n  + UpdateJobPayment(jobId: int, paymentAmount: int)\n  + GetPaidJobs(jobType: string, expLevel: string) : List&lt;JobPaymentInfo&gt;\n  + GetCompaniesToNotify(jobId: int, amount: int) : List&lt;string&gt;\n}\n\nclass JobPaymentInfo {\n  + CompanyName : string\n  + JobTitle : string\n  + AmountPayed : int\n}\n\nPaymentWindow --&gt; PaymentViewModel : Binds to\nPaymentViewModel --&gt; PaymentService : Orchestrates\nPaymentViewModel o-- JobPaymentInfo : Holds List of\nPaymentService --&gt; PaymentValidator : Uses\nPaymentService --&gt; PaymentRepository : Uses\nPaymentRepository ..&gt; JobPaymentInfo : Creates\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;txt&quot;&#xa;}" id="d1K7fC0HMbFR0bBq64Bf-3">
