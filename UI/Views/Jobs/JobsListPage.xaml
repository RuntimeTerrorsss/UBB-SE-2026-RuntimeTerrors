<Page
    x:Class="iss_project.UI.Views.Jobs.JobsListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Grid Padding="20">
		<StackPanel Spacing="10">

			<TextBlock Text="Jobs" FontSize="24" />

			<ListView ItemsSource="{Binding Jobs}">
				<ListView.ItemTemplate>
					<DataTemplate>
						<StackPanel Spacing="5" Margin="5">

							<TextBlock Text="{Binding JobTitle}" FontWeight="Bold"/>
							<TextBlock Text="{Binding IndustryField}" />
							<TextBlock Text="{Binding JobLocation}" />
							<TextBlock Text="{Binding AvailablePositions}" />

						</StackPanel>
					</DataTemplate>
				</ListView.ItemTemplate>
			</ListView>

		</StackPanel>
		<Button Content="Back to Create Job" Click="GoToCreate"/>
	</Grid>
</Page>